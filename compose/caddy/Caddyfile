# Caddy reverse proxy (T2.9) — localhost TLS, API'yi iç ağda tutar.
#
# Dev compose yığını için: 443'te TLS terminasyonu (Caddy'nin internal CA'sı; tarayıcı bir kez
# "Bu siteye git" diye uyaracak), 80 → 443 yönlendirme. /api/* ve /health* → api:8080 iç ağda.
# Diğer yollar: /srv altındaki web SPA build'i (compose/caddy/Dockerfile imaja gömer;
# SPA fallback → index.html). Geliştirmede Vite (`pnpm dev`, 5173) ayrıca kullanılabilir.
#
# Production (gerçek domain) için: `localhost` yerine domain adı, `tls internal` yerine
# Let's Encrypt'le otomatik HTTPS (Caddy varsayılanı zaten). 11 §5 + 10 §5.

{
	# Otomatik HTTP→HTTPS yönlendirme açık (Caddy varsayılanı): 80 → 308 → 443.
	# Localhost için internal CA → site bloğundaki `tls internal` ile.
	# Log'lar stdout (compose log driver toplar → T2.8 ile Seq).
}

localhost {
	tls internal

	# Güvenlik başlıkları (11 §5). HSTS yalnız HTTPS akışı doğrulandıktan sonra (preload yok).
	header {
		# XSS/clickjacking/MIME-sniffing temel korumalar
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# HSTS (1 yıl) — geliştirme tarayıcısında localhost için cache temizlemek isteyebilirsin.
		Strict-Transport-Security "max-age=31536000"
		# Caddy header
		-Server
	}

	encode gzip zstd

	# SPA girişi asla bayat kalmasın: index.html her istekte doğrulanır (deploy sonrası
	# kullanıcı eski JS/CSS paketiyle kalmasın — 2026-07-12 grafik geri bildirimi).
	# Hash'li Vite asset'leri içerik-adresli → 1 yıl immutable cache güvenli.
	@entry path / /index.html
	header @entry Cache-Control "no-cache"
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# API rotaları — backend container iç ağda 8080'de.
	handle /api/* {
		reverse_proxy api:8080
	}

	# Health endpoint'leri — uptime izleme + container orchestration (rate limit yok, T2.9.b).
	handle /health* {
		reverse_proxy api:8080
	}

	# Web SPA — imaja gömülü statik build. Bilinmeyen yollar index.html'e düşer
	# (client-side routing); gerçek dosyalar (JS/CSS/font) doğrudan sunulur.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}
