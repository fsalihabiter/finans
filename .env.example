# `.env` — yerel ortam değişkenleri (REPODA YOK, .gitignore'da). Bu dosyayı `.env` olarak
# kopyala ve değerleri kendi anahtarlarınla doldur: `cp .env.example .env` (veya elle).
#
# docker-compose.yml bu değişkenleri okur. Compose dışı (yerel `dotnet run`) için User Secrets
# kullan (`dotnet user-secrets set "Llm:ApiKey" "..."` — backend/src/Finans.Api dizininden).

# Postgres compose servisinin parolası (compose içi DB). Yerel `dotnet run` kendi PostgreSQL'i ile.
POSTGRES_PASSWORD=finans_dev

# LLM sağlayıcı (T3.1 — 07). Compose üzerinden API çalıştırırken kullanılır.
#   Provider: Anthropic | OpenRouter
#
# ÖNERİLEN — Anthropic (2026-07-11'den beri kullanılan; kusursuz Türkçe + şema uyumu,
# üretim başına ~1-2 sent Haiku ile; daha zengin dil için claude-sonnet-4-6):
LLM_PROVIDER=Anthropic
LLM_API_KEY=sk-ant-BURAYA_KENDI_KEY
LLM_MODEL=claude-haiku-4-5-20251001
LLM_BASE_URL=https://api.anthropic.com/
#
# Ücretsiz alternatif — OpenRouter (kalite değişken: dil sızıntısı/eksik kart görülebilir;
# deterministik bekçiler ayıklar ama tam kapsama garanti edilemez):
#   LLM_PROVIDER=OpenRouter
#   LLM_API_KEY=sk-or-v1-BURAYA_KENDI_KEY
#   LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
#   LLM_BASE_URL=https://openrouter.ai/api/

# Grafana admin parolası (T2.8 — gözlem yığını). Dev varsayılanı `admin` (compose).
# GRAFANA_ADMIN_PASSWORD=admin
